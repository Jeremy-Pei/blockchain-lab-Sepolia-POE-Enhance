# ══════════════════════════════════════════════════════════
# macOS
# ══════════════════════════════════════════════════════════
.DS_Store

# ══════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ══════════════════════════════════════════════════════════
# Environment variables and secrets (⚠️ CRITICAL)
# ══════════════════════════════════════════════════════════
.env
*.env
!.env.example

# ══════════════════════════════════════════════════════════
# Local databases
# ══════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3

# ══════════════════════════════════════════════════════════
# Generated evidence and reports (keep directory, ignore content)
# ══════════════════════════════════════════════════════════
python-client/evidence/*.json
python-client/reports/*.md
python-client/reports/*.pdf
python-client/packages/*.zip
python-client/packages/evidence_package_*/
!python-client/evidence/.gitkeep
!python-client/reports/.gitkeep
!python-client/packages/.gitkeep

# ══════════════════════════════════════════════════════════
# IPFS mock storage and downloads (Stage 7)
# ══════════════════════════════════════════════════════════
python-client/mock_ipfs_storage/

# ══════════════════════════════════════════════════════════
# Batch Merkle evidence packages and reports (Stage 9)
# ══════════════════════════════════════════════════════════
python-client/evidence/batches/*
!python-client/evidence/batches/.gitkeep
python-client/packages/batches/*
!python-client/packages/batches/.gitkeep
python-client/reports/batches/*
!python-client/reports/batches/.gitkeep

# ══════════════════════════════════════════════════════════
# Encrypted / decrypted / downloaded working files (Stage 8)
# Never commit ciphertext, recovered plaintext, or downloaded blobs.
# ══════════════════════════════════════════════════════════
python-client/encrypted/*
!python-client/encrypted/.gitkeep
python-client/decrypted/*
!python-client/decrypted/.gitkeep
python-client/downloads/*
!python-client/downloads/.gitkeep

# ══════════════════════════════════════════════════════════
# Stage 10: FastAPI service upload / temp directories
# ══════════════════════════════════════════════════════════
python-client/uploads/*
!python-client/uploads/.gitkeep
python-client/api_tmp/*
!python-client/api_tmp/.gitkeep

# ══════════════════════════════════════════════════════════
# Works: keep only sample files
# ══════════════════════════════════════════════════════════
python-client/works/*
!python-client/works/sample_work.txt
!python-client/works/.gitkeep

# ══════════════════════════════════════════════════════════
# Foundry / Solidity build outputs
# ══════════════════════════════════════════════════════════
contracts/out/
contracts/cache/
contracts/broadcast/

# ══════════════════════════════════════════════════════════
# C++ build
# ══════════════════════════════════════════════════════════
build/
cmake-build-*/
*.o
*.a
*.dylib
*.so
*.exe

# ══════════════════════════════════════════════════════════
# IDE / Editor
# ══════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo

# ══════════════════════════════════════════════════════════
# Claude Code local settings
# ══════════════════════════════════════════════════════════
.claude/

# ══════════════════════════════════════════════════════════
# Logs
# ══════════════════════════════════════════════════════════
*.log

# ══════════════════════════════════════════════════════════
# Agent skills (obsidian-skills, installed via npx skills)
# ══════════════════════════════════════════════════════════
.agents/
.claude/skills/
skills-lock.json
