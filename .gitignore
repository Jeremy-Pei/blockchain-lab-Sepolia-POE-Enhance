# ══════════════════════════════════════════════════════════
# macOS
# ══════════════════════════════════════════════════════════
.DS_Store

# ══════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ══════════════════════════════════════════════════════════
# Environment variables and secrets (⚠️ CRITICAL)
# ══════════════════════════════════════════════════════════
.env
*.env
!.env.example

# ══════════════════════════════════════════════════════════
# Local databases
# ══════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3

# ══════════════════════════════════════════════════════════
# Generated evidence and reports (keep directory, ignore content)
# ══════════════════════════════════════════════════════════
python-client/evidence/*.json
python-client/reports/*.md
python-client/reports/*.pdf
!python-client/evidence/.gitkeep
!python-client/reports/.gitkeep

# ══════════════════════════════════════════════════════════
# Works: keep only sample files
# ══════════════════════════════════════════════════════════
python-client/works/*
!python-client/works/sample_work.txt
!python-client/works/.gitkeep

# ══════════════════════════════════════════════════════════
# Foundry / Solidity build outputs
# ══════════════════════════════════════════════════════════
contracts/out/
contracts/cache/
contracts/broadcast/

# ══════════════════════════════════════════════════════════
# C++ build
# ══════════════════════════════════════════════════════════
build/
cmake-build-*/
*.o
*.a
*.dylib
*.so
*.exe

# ══════════════════════════════════════════════════════════
# IDE / Editor
# ══════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo

# ══════════════════════════════════════════════════════════
# Logs
# ══════════════════════════════════════════════════════════
*.log
