# ══════════════════════════════════════════════════════════
# Proof-of-Existence Python Client — Environment Variables
# ══════════════════════════════════════════════════════════
#
# 使用方法:
#   1. 复制此文件: cp .env.example .env
#   2. 填入你的真实配置
#   3. 确保 .env 已被 .gitignore 忽略（不要提交到 Git）
#
# ⚠️ 安全提醒:
#   - PRIVATE_KEY 绝对不能上传到 GitHub
#   - 即使是测试钱包私钥，也建议保密
#   - RPC_URL 中的 API Key 也属于敏感信息

# ── 网络配置 ──
NETWORK_NAME=Sepolia
CHAIN_ID=11155111

# ── RPC 节点（替换为你的 API Key）──
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# ── 钱包私钥（替换为你的测试钱包私钥）──
PRIVATE_KEY=your_test_wallet_private_key_here_64_hex_chars

# ── 已部署的合约地址 ──
CONTRACT_ADDRESS=0xyour_contract_address_here

# ── 区块浏览器 ──
EXPLORER_TX_URL=https://sepolia.etherscan.io/tx/
