# ══════════════════════════════════════════════════════════
# Proof-of-Existence Python Client — Environment Variables
# ══════════════════════════════════════════════════════════
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values
#   3. Make sure .env is listed in .gitignore (never commit it)
#
# ⚠️ Security reminder:
#   - Never upload PRIVATE_KEY to GitHub
#   - Keep even test wallet private keys confidential
#   - The API Key embedded in RPC_URL is also sensitive

# ── Default Network (Stage 12) ─────────────────────────────
# Which network the system uses when --network is not specified.
# One of: anvil, sepolia, base_sepolia
DEFAULT_NETWORK=sepolia

# ── Wallet private key (shared across networks in Stage 12) ──
# Replace with your test wallet private key (never a mainnet key)
PRIVATE_KEY=your_test_wallet_private_key_here_64_hex_chars

# ══════════════════════════════════════════════════════════
# Anvil (local Foundry test node)
# ══════════════════════════════════════════════════════════
ANVIL_RPC_URL=http://127.0.0.1:8545
ANVIL_CONTRACT_ADDRESS=

# ══════════════════════════════════════════════════════════
# Ethereum Sepolia testnet
# ══════════════════════════════════════════════════════════
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE
SEPOLIA_CONTRACT_ADDRESS=0xyour_sepolia_contract_address_here

# ══════════════════════════════════════════════════════════
# Base Sepolia testnet
# ══════════════════════════════════════════════════════════
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE
BASE_SEPOLIA_CONTRACT_ADDRESS=

# ══════════════════════════════════════════════════════════
# Legacy single-network variables (still read by config.py for
# fallback / backward-compatibility with pre-Stage-12 code)
# ══════════════════════════════════════════════════════════
NETWORK_NAME=Sepolia
CHAIN_ID=11155111
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE
CONTRACT_ADDRESS=0xyour_contract_address_here
EXPLORER_TX_URL=https://sepolia.etherscan.io/tx/

# ══════════════════════════════════════════════════════════
# Contract deployment (Stage 13)
# ══════════════════════════════════════════════════════════
# Path to the Foundry artifact produced by `forge build` in contracts/.
# Relative paths are resolved from python-client/.  Leave unset to use the
# default: ../contracts/out/ProofOfExistence.sol/ProofOfExistence.json
FOUNDRY_ARTIFACT_PATH=../contracts/out/ProofOfExistence.sol/ProofOfExistence.json

# ══════════════════════════════════════════════════════════
# IPFS — off-chain content-addressed storage (Stage 7)
# ══════════════════════════════════════════════════════════
#
# IPFS_PROVIDER selects the storage backend:
#   mock   → local content store, no network needed (default, used by tests)
#   pinata → Pinata pinning service (requires a real PINATA_JWT below)
IPFS_PROVIDER=mock

# Public gateway used to build browsable URLs and to download files
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/

# ── Pinata pinning service (only needed when IPFS_PROVIDER=pinata) ──
# ⚠️ Never commit a real PINATA_JWT — keep it only in your local .env
PINATA_JWT=your_pinata_jwt_here
PINATA_API_URL=https://api.pinata.cloud
